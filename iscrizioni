<!-- Script di integrazione -->

<script>
    // ============================================
    // CONFIGURAZIONE FIREBASE
    // ============================================
    // TODO: Sostituisci questi valori con le TUE credenziali da Firebase Console
    const firebaseConfig = {
        apiKey: "YOUR_API_KEY",
        authDomain: "YOUR_AUTH_DOMAIN",
        projectId: "YOUR_PROJECT_ID",
        storageBucket: "YOUR_STORAGE_BUCKET",
        messagingSenderId: "YOUR_MESSAGING_SENDER_ID",
        appId: "YOUR_APP_ID",
        measurementId: "YOUR_MEASUREMENT_ID"
    };

    // Inizializza Firebase
    firebase.initializeApp(firebaseConfig);
    const db = firebase.firestore();

    // ============================================
    // CORSI DISPONIBILI
    // ============================================
    const COURSES = {
        'lego-spike': { name: 'Lego Spike Prime', age: '8–13 anni', max: 10 },
        'arduino': { name: 'Arduino', age: '12–16 anni', max: 10 },
        'open-roberta': { name: 'Open Roberta', age: '8–13 anni', max: 10 },
        'microbit': { name: 'micro:bit BBC', age: '8–13 anni', max: 10 },
        'mattine-coding': { name: 'Mattine di coding', age: '8–13 anni', max: 12 },
    };

    // ============================================
    // POPOLA I CORSI
    // ============================================
    async function populateCourses() {
        const coursesGrid = document.getElementById('coursesGrid');
        coursesGrid.innerHTML = ''; // Pulisci
        
        for (const [courseId, courseInfo] of Object.entries(COURSES)) {
            try {
                // Conta iscritti confermati
                const snapshot = await db.collection('enrollments')
                    .where('courseId', '==', courseId)
                    .where('status', '==', 'confermato')
                    .get();
                
                const confirmed = snapshot.size;
                const available = Math.max(0, courseInfo.max - confirmed);
                const isFull = available === 0;
                
                // Crea elemento HTML
                const courseHTML = `
                    <div class="course-option">
                        <input type="radio" id="course-${courseId}" name="courseId" value="${courseId}" ${isFull ? 'disabled' : ''}>
                        <label for="course-${courseId}" class="course-label">
                            <strong>${courseInfo.name}</strong>
                            <small>${courseInfo.age}</small>
                            <div class="course-availability ${isFull ? 'full' : available <= 2 ? 'limited' : 'available'}">
                                ${isFull ? '❌ Corso Pieno' : `✓ ${available} posti liberi`}
                            </div>
                        </label>
                    </div>
                `;
                
                coursesGrid.innerHTML += courseHTML;
            } catch (error) {
                console.error('Errore caricamento corso:', error);
            }
        }
    }

    // ============================================
    // SUBMIT FORM
    // ============================================
    document.getElementById('enrollmentForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Nascondi messaggi precedenti
        document.getElementById('successMessage').classList.remove('show');
        document.getElementById('errorMessage').classList.remove('show');
        document.getElementById('waitlistMessage').classList.remove('show');
        
        // Disabilita bottone
        const submitBtn = document.querySelector('.submit-btn');
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="loading-spinner"></span> Elaborazione...';
        
        try {
            // Raccogli dati
            const courseId = document.querySelector('input[name="courseId"]:checked');
            if (!courseId) {
                throw new Error('Seleziona un corso');
            }

            const formData = {
                studentName: document.getElementById('studentName').value,
                studentAge: document.getElementById('studentAge').value,
                parentName: document.getElementById('parentName').value,
                parentEmail: document.getElementById('parentEmail').value,
                parentPhone: document.getElementById('parentPhone').value,
                schoolName: document.getElementById('schoolName').value,
                courseId: courseId.value,
                referral: document.getElementById('referral').value,
                notes: document.getElementById('notes').value,
            };
            
            // Validazione
            if (!formData.studentName || !formData.studentAge || !formData.parentEmail || !formData.courseId) {
                throw new Error('Completa tutti i campi obbligatori');
            }
            
            // Controlla posti disponibili
            const courseInfo = COURSES[formData.courseId];
            const snapshot = await db.collection('enrollments')
                .where('courseId', '==', formData.courseId)
                .where('status', '==', 'confermato')
                .get();
            
            const confirmed = snapshot.size;
            let status = 'confermato';
            let waitlistPosition = null;
            
            if (confirmed >= courseInfo.max) {
                status = 'in_attesa';
                waitlistPosition = confirmed - courseInfo.max + 1;
            }
            
            // Salva su Firebase
            const docRef = await db.collection('enrollments').add({
                studentName: formData.studentName,
                studentAge: parseInt(formData.studentAge),
                parentName: formData.parentName,
                parentEmail: formData.parentEmail,
                parentPhone: formData.parentPhone,
                schoolName: formData.schoolName,
                courseId: formData.courseId,
                courseName: courseInfo.name,
                status: status,
                waitlistPosition: waitlistPosition,
                paid: false,
                referral: formData.referral,
                notes: formData.notes,
                enrollmentDate: new Date(),
            });
            
            console.log('✅ Iscritto salvato con ID:', docRef.id);
            
            // Mostra messaggio appropriato
            if (status === 'in_attesa') {
                document.getElementById('waitlistText').innerText = 
                    `Sei in lista d'attesa (posizione ${waitlistPosition}). Ti contatteremo se si libera un posto!`;
                document.getElementById('waitlistMessage').classList.add('show');
            } else {
                document.getElementById('successText').innerText = 
                    'Iscrizione confermata! Riceverai email di conferma.';
                document.getElementById('successMessage').classList.add('show');
            }
            
            // Resetta form
            document.getElementById('enrollmentForm').reset();
            
            // Ricarica corsi per aggiornare posti
            setTimeout(() => {
                populateCourses();
            }, 1000);
            
        } catch (error) {
            console.error('❌ Errore:', error);
            document.getElementById('errorText').innerText = error.message || 'Errore durante l\'iscrizione. Riprova.';
            document.getElementById('errorMessage').classList.add('show');
        } finally {
            // Riabilita bottone
            submitBtn.disabled = false;
            submitBtn.innerHTML = '✨ Iscriviti Subito!';
        }
    });

    // Popola corsi al caricamento della pagina
    populateCourses();
</script>

